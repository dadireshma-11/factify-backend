PORT=5000
MONGO_URI=mongodb://localhost:27017/
JWT_SECRET=your_jwt_secret_here
# Replace the GEMINI API key with your own in production
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Gmail SMTP (required for email alerts, 2FA OTP, login alerts)
# Provide your Gmail address and an App Password (not your regular password)
SMTP_EMAIL=REPLACE_WITH_YOUR_EMAIL
SMTP_APP_PASSWORD=REPLACE_WITH_YOUR_GMAIL_APP_PASSWORD

# Contact form + alerts (Gmail SMTP — must be App Password, not normal password)
EMAIL_USER=REPLACE_WITH_YOUR_EMAIL
EMAIL_PASS=REPLACE_WITH_YOUR_EMAIL_APP_PASSWORD
# Optional: use port 587 if 465 is blocked
# SMTP_PORT=587
